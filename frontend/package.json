{
  "name": "sticker-material-organizer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder --win",
    "electron:start": "electron .",
    "cap:add": "npx cap add",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open",
    "cap:build": "npm run build && npx cap sync"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "antd": "^6.5.0",
    "antd-mobile": "^5.42.3",
    "axios": "^1.18.1",
    "konva": "^10.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-konva": "^19.2.5",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "com.sticker.material-organizer",
    "productName": "手账素材库",
    "directories": {
      "output": "release4"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules"
    ],
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      },
      {
        "from": "../data",
        "to": "data"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
